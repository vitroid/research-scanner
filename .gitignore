# --- Python -------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.eggs/

# --- Virtual environments / tooling caches ------------------------------
.venv/
venv/
env/
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# --- Poetry -------------------------------------------------------------
# このプロジェクトは Dropbox 配下にあり、複数マシンで lock を共有すると
# 同期競合 / プラットフォーム差異の問題が出るため lock はコミットしない。
# 仮想環境も in-project (.venv/) ではなく Poetry のキャッシュ側に置く (poetry.toml 参照)。
poetry.lock
dist/
.poetry-cache/

# --- Generated data & reports (regeneratable from src/scripts) ----------
data/
outputs/

# --- Notebook artifacts -------------------------------------------------
.ipynb_checkpoints/
# Scratch executed copy used by CI / smoke runs (notebooks/_executed.ipynb etc.)
notebooks/_executed*.ipynb
notebooks/*.executed.ipynb

# --- Secrets ------------------------------------------------------------
.env
.env.*
!.env.example

# --- OS / editor --------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
.cursor/
